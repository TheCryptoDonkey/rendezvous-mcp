{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.forgesworn/rendezvous-mcp",
  "description": "Fair meeting point discovery for AI agents. Isochrone-based travel time fairness scoring, OSM venue search, multiple routing engines. The only MCP server for location fairness.",
  "repository": {
    "url": "https://github.com/forgesworn/rendezvous-mcp",
    "source": "github"
  },
  "version_detail": {
    "version": "1.1.1"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "rendezvous-mcp",
      "version": "1.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Valhalla routing engine URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "VALHALLA_URL"
        }
      ]
    }
  ]
}
